      "default_width": 1920,
      "default_height": 1080,
      "enabled": true,
      "properties": {
        "show_timer": true,
        "show_counters": true,
        "liquid_glass": true
      }
    },
    {
      "id": "gauge",
      "name": "Circular Gauge",
      "file": "gauge.html",
