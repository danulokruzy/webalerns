{
  "widgets": {
    "progress": {
      "name": "Progress Bar",
      "route": "/prog",
      "description": "Прогресс-бар с таймером TikTok",
      "enabled": true,
      "config": {
        "width": 1920,
        "height": 1080,
        "update_interval": 100,
        "auto_refresh": true
      }
    },
    "vip": {
      "name": "VIP Widget",
      "route": "/vip",
      "description": "VIP уведомления",
      "enabled": true,
      "config": {
        "width": 1920,
        "height": 1080,
        "update_interval": 500
      }
    },
    "gauge": {
      "name": "Circular Gauge",
      "route": "/gauge",
      "description": "Круглый gauge с градиентом",
      "enabled": true,
      "config": {
        "width": 600,
        "height": 600,
        "update_interval": 200,
        "show_percentage": true
      }
    },
    "chat": {
      "name": "Live Chat",
      "route": "/chat",
      "description": "Чат с жидким стеклом эффектом",
      "enabled": true,
      "config": {
        "width": 400,
        "height": 600,
        "update_interval": 300,
        "max_messages": 50,
        "position": "bottom-left"
      }
    },
    "donation": {
      "name": "Donation Tracker",
      "route": "/donation",
      "description": "Отслеживание донатов с лидербордом",
      "enabled": true,
      "config": {
        "width": 1920,
        "height": 1080,
        "update_interval": 500,
        "show_total": true,
        "max_recent": 10
      }
    }
  },
  "scenes": {
    "default": {
      "name": "Main Stream",
      "widgets": ["progress"],
      "layout": "center"
    },
    "intermission": {
      "name": "Intermission",
      "widgets": ["gauge", "chat"],
      "layout": "side-by-side"
    },
    "donation-alert": {
      "name": "Donation Alert",
      "widgets": ["donation"],
      "layout": "center",
      "duration_ms": 5000
    },
    "all-widgets": {
      "name": "Full Dashboard",
      "widgets": ["progress", "gauge", "chat", "donation"],
      "layout": "grid"
    }
  },
  "settings": {
    "server_url": "http://localhost:5000",
    "auto_refresh": true,
    "refresh_interval": 100,
    "debug_mode": false,
    "enable_websocket": false,
    "tiktok_username": "danulo.kruz",
    "default_scene": "default"
  },
  "liquid_glass_presets": {
    "bright": {
      "blur": "18px",
      "saturate": "200%",
      "brightness": "1.1",
      "description": "Яркое, стандартное"
    },
    "dark": {
      "blur": "15px",
      "saturate": "180%",
      "brightness": "0.95",
      "description": "Тёмное, приглушённое"
    },
    "intense": {
      "blur": "25px",
      "saturate": "300%",
      "brightness": "1.3",
      "description": "Очень яркое и размытое"
    },
    "subtle": {
      "blur": "8px",
      "saturate": "120%",
      "brightness": "0.85",
      "description": "Едва заметное, минималистичное"
    },
    "cyber": {
      "blur": "20px",
      "saturate": "250%",
      "brightness": "1.2",
      "description": "Киберпанковский стиль"
    }
  }
}
